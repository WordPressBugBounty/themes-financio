    "styles": {
        "spacing": {
            "blockGap": "1.2rem"
        },
        "blocks": {
            "core/post-content": {
                "spacing": {
                    "margin": {
                        "top": "0px"
                    }
                }
            },
            "core/list": {
                "spacing": {
                    "padding": {
                        "right": "15px",
                        "left": "15px"
                    }
                }
            },
            "core/columns": {
                "spacing": {
                    "blockGap": {
                        "top": "20px"
                    }
                }
            },
            "core/column": {
                "spacing": {
                    "padding": {
                        "top": "10px",
                        "bottom": "10px"
                    }
                }
            }
        },
        "elements": {
            "link": {
                "typography": {
                    "textDecoration": "underline"
                },
                "color": {
                    "text": "var:preset|color|theme-0"
                },
                ":hover": {
                    "color": {
                        "text": "var:preset|color|theme-11"
                    }
                }
            },
            "button": {
                "color": {
                    "background": "var:preset|color|theme-0",
                    "text": "var:preset|color|white"
                }
            },
            "heading": {
                "color": {
                    "text": "var:preset|color|theme-1"
                }
            }
        },
        "color": {
            "text": "var:preset|color|theme-2"
        }
    },
